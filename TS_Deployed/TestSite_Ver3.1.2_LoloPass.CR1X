'TELEMETRY SETUP CONSTANTS
ConstTable (ConstSetup,0)
  Const HasBaro As Boolean = True
  #If HasBaro
    Const Elevation_ft = 5280
  #EndIf
  Const HasStevens As Boolean = True
  #If HasStevens
    Const NumStevens = 3
  #EndIf
  Const HasAcclima As Boolean = True
  #If HasAcclima
    Const NumAcclima = 3
  #EndIf
  Const HasSnowTemp As Boolean = True
  #If HasSnowTemp
    Const NumSnowTemp = 18 '18 for 3.4m cable, 28 for 5.4m cable
  #EndIf
  Const HasLluft As Boolean = False
  Const HasGeonor As Boolean = False
  #If HasGeonor
    Const Geonor_Sensor1_A As Double = 0.0290991R ' Sensor 1 SN 97221
    Const Geonor_Sensor1_B As Double = 0.0000158571R
    Const Geonor_Sensor1_F0 = 1108.6
    Const Geonor_Sensor2_A As Double = 0.0295759R ' Sensor 2 SN 97321
    Const Geonor_Sensor2_B As Double = 0.0000157010R
    Const Geonor_Sensor2_F0 = 1119.6
  #EndIf
  Const HasRadarPCP As Boolean = False
  Const XtraRad As Boolean = False '2nd Net Rad Sensor
  Const XtraDeep As Boolean = False '2nd Sommer US9 Sensor
  Const FastSlow = 10 'Seconds between Faster Slow Sequence Scans. Modded to test SDI-12 Response
  'GOES Variables
  Const GOES As Boolean = True  ' true if using GOES, false if not
  #If GOES
    Const GOESID = "5DA25306" 'Enter the GoesID number / platform ID.
    Const PTXChannel = "304"   'Enter the primary transmit channel assigned to the GOES ID
    Const PTXTime = "00:09:10"   'Enter the primary transmit time assigned to the GOES ID. The format for this is "00:00:00".Example: 00:58:10 for a transmit 58 mins and 10 secs after the hour
    Const PTXSatType = "1"   'Enter 0 for 300 baud, 1 for 1200 baud
    Const PTXPwrLvl = "14.00"   'Set the power level based on which antenna is used.1.25 for Directional Yagi, 7 for Omnidirectional (FTS or Sutron 2:1).
    Const RTXChannel = "128"   'Random Transmission Channel sets which satellite it reports to. 195 for East, 196 for West
    Const Num_of_Hours_TX = 5   'Set the number of hours of data to be transmitted per hour
    Const LocTimeOffset = "-480"
    Const ComPort = ComME  'This is the setup for an SC105 with the port programmed to ComME vs SDC6/7
    Const Count = 16 'number of radio setup commands
    Const RTXSatType = "1"   'Enter 0 for 300 baud, 1 for 1200 baud
    Const RTXPwrLvl = "14.00"  'Set the power level based on which antenna is used.1.25 for Directional Yagi, 7 for Omnidirectional (FTS or Sutron 2:1).
  #EndIf
EndConstTable

Const AutoTimeConstraint_Min As Long = 2 ' time in minutes
Const AutoTimeUpdateInterval As Long = 129600 ' time in minutes. Set for every 3 months (90 days) 129600

